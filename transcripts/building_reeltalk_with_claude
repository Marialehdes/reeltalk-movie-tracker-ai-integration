● Here's the recommended structure and rationale:

  Recommended Data Structure

  // localStorage key: "reeltalk_user_movies"

  {
    "tt0111161": {
      "watched": true,
      "favorite": false,
      "rating": 5,
      "watchedAt": "2026-03-10T14:22:00Z",
      "updatedAt": "2026-03-10T14:22:00Z"
    },
    "tt0068646": {
      "watched": false,
      "favorite": true,
      "rating": null,
      "watchedAt": null,
      "updatedAt": "2026-03-11T09:00:00Z"
    }
  }

  Keyed by movie ID — O(1) lookups, updates, and deletes by ID. Far better than
  an array for CRUD.

  ---
  Why Not an Array?

  An array like [{ id, watched, rating }] forces you to iterate on every
  read/write. A map (plain object keyed by ID) avoids that entirely.

  ---
  CRUD Operations

  const STORAGE_KEY = "reeltalk_user_movies";

  function getUserMovies() {
    return JSON.parse(localStorage.getItem(STORAGE_KEY) ?? "{}");
  }

  function saveUserMovies(data) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
  }

  // Create / Update a field
  function updateMovie(id, changes) {
    const data = getUserMovies();
    data[id] = {
      watched: false,
      favorite: false,
      rating: null,
      watchedAt: null,
      ...data[id],         // preserve existing fields
      ...changes,          // apply new changes
      updatedAt: new Date().toISOString(),
    };
    saveUserMovies(data);
  }

  // Read one
  function getMovie(id) {
    return getUserMovies()[id] ?? null;
  }

  // Delete one
  function removeMovie(id) {
    const data = getUserMovies();
    delete data[id];
    saveUserMovies(data);
  }

  ---
  Filtering

  Since your movie metadata (title, genre) lives in your separate dataset,
  filtering is a two-step join:

  // Get all watched movies
  function getWatched(allMovies) {
    const data = getUserMovies();
    return allMovies.filter(m => data[m.id]?.watched === true);
  }

  // Get favorites with their rating
  function getFavorites(allMovies) {
    const data = getUserMovies();
    return allMovies
      .filter(m => data[m.id]?.favorite === true)
      .map(m => ({ ...m, rating: data[m.id].rating }));
  }

  // Get movies rated above N stars
  function getByMinRating(allMovies, min) {
    const data = getUserMovies();
    return allMovies.filter(m => (data[m.id]?.rating ?? 0) >= min);
  }

  ---
  Key Design Decisions

  ┌──────────────────────────────┬──────────────────────────────────────────┐
  │           Decision           │                  Reason                  │
  ├──────────────────────────────┼──────────────────────────────────────────┤
  │ Keyed by movie ID            │ O(1) CRUD, no searching                  │
  ├──────────────────────────────┼──────────────────────────────────────────┤
  │ User data separate from      │ Movie catalog is read-only; don't mix    │
  │ movie data                   │ concerns                                 │
  ├──────────────────────────────┼──────────────────────────────────────────┤
  │ null for unset rating        │ Distinguishes "not rated" from a 0-star  │
  │                              │ rating                                   │
  ├──────────────────────────────┼──────────────────────────────────────────┤
  │ watchedAt timestamp          │ Enables "recently watched" sorting for   │
  │                              │ free later                               │
  ├──────────────────────────────┼──────────────────────────────────────────┤
  │ Default spread in            │ Safe upsert — works for both create and  │
  │ updateMovie                  │ update                                   │
  └──────────────────────────────┴──────────────────────────────────────────┘

  ---
  Usage Examples

  // Mark as watched
  updateMovie("tt0111161", { watched: true, watchedAt: new Date().toISOString()
  });

  // Rate a movie
  updateMovie("tt0111161", { rating: 4 });

  // Toggle favorite
  const current = getMovie("tt0111161");
  updateMovie("tt0111161", { favorite: !current?.favorite });

  This structure scales cleanly if you ever migrate to a backend — the shape
  maps directly to a user-movie join table with the same fields.

